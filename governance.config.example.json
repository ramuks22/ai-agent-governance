{
  "configVersion": "1.0",
  "tracker": {
    "path": "docs/tracker.md",
    "idPattern": "^[A-Z]+-[A-Z]+-\\d{3}$",
    "allowedPrefixes": [
      "AG",
      "SEC",
      "UX",
      "DOC"
    ]
  },
  "gates": {
    "preCommit": [
      "npm run -s format:check",
      "npm run -s lint"
    ],
    "prePush": [
      "npm run -s test",
      "npm run -s build"
    ]
  },
  "ci": {
    "preCiCommand": "npm run codegen"
  },
  "branchProtection": {
    "blockDirectPush": [
      "main",
      "master"
    ],
    "branchNamePattern": "^(feat|fix|hotfix|chore|docs|refactor|test|perf|build|ci|revert|release)\\/[a-z0-9._-]+(?:\\/[a-z0-9._-]+)*$"
  },
  "node": {
    "minVersion": "20.0.0"
  }
}
