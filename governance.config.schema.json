{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Agent Governance Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "configVersion",
    "tracker",
    "gates",
    "node"
  ],
  "properties": {
    "configVersion": {
      "type": "string"
    },
    "tracker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "idPattern"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "idPattern": {
          "type": "string"
        },
        "allowedPrefixes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preCommit",
        "prePush"
      ],
      "properties": {
        "preCommit": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prePush": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preCiCommand": {
          "type": "string",
          "pattern": "\\S"
        }
      }
    },
    "agentic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "roleRegistryPath",
        "skillRegistryPath",
        "adapterRegistryPath",
        "generatedAdapterPath",
        "handoffArtifactPath",
        "retrospectiveArtifactPath",
        "retrospectiveRequiredFor",
        "maxParallelWriters",
        "allowReadOnlyParallelism",
        "requireBoundedOwnership",
        "adapterGenerationMode"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "roleRegistryPath": {
          "type": "string",
          "pattern": "\\S"
        },
        "skillRegistryPath": {
          "type": "string",
          "pattern": "\\S"
        },
        "adapterRegistryPath": {
          "type": "string",
          "pattern": "\\S"
        },
        "generatedAdapterPath": {
          "type": "string",
          "pattern": "\\S"
        },
        "handoffArtifactPath": {
          "type": "string",
          "pattern": "\\S"
        },
        "retrospectiveArtifactPath": {
          "type": "string",
          "pattern": "\\S"
        },
        "retrospectiveRequiredFor": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "\\S"
          }
        },
        "maxParallelWriters": {
          "type": "integer",
          "minimum": 1
        },
        "allowReadOnlyParallelism": {
          "type": "boolean"
        },
        "requireBoundedOwnership": {
          "type": "boolean"
        },
        "adapterGenerationMode": {
          "type": "string",
          "enum": [
            "checked-in"
          ]
        }
      }
    },
    "branchProtection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blockDirectPush": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "branchNamePattern": {
          "type": "string"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minVersion"
      ],
      "properties": {
        "minVersion": {
          "type": "string"
        }
      }
    }
  }
}
