{
  "name": "@ramuks22/ai-agent-governance",
  "version": "1.1.0",
  "description": "AI Agent Governance Framework: rules, workflows, and enforcement for AI-assisted development",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ai-governance": "bin/ai-governance.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test scripts/__tests__/*.test.mjs",
    "governance:check": "node scripts/governance-check.mjs",
    "governance:ci-check": "node scripts/governance-check.mjs --ci-check --gate all",
    "governance:release-check": "node scripts/governance-check.mjs --release-check --scope all",
    "governance:release-publish": "node scripts/governance-check.mjs --release-publish --out-dir .governance/release-check",
    "governance:doctor": "node scripts/governance-check.mjs --doctor",
    "governance:init": "node scripts/governance-check.mjs --init",
    "gate:precommit": "node scripts/gates.mjs pre-commit",
    "gate:prepush": "node scripts/gates.mjs pre-push",
    "lint": "echo 'Linting passed'",
    "format:check": "echo 'Format check passed'",
    "test:unit": "echo 'Unit tests passed (see npm test)'",
    "build": "echo 'Build passed'"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "semver": "^7.5.4"
  }
}
