{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Role Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registryVersion",
    "roles"
  ],
  "properties": {
    "registryVersion": {
      "type": "string"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose",
          "trigger_conditions",
          "scope",
          "read_only",
          "owned_paths",
          "inputs",
          "outputs",
          "validation_scope",
          "overlap_rules",
          "retirement_conditions"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "\\S"
          },
          "purpose": {
            "type": "string",
            "pattern": "\\S"
          },
          "trigger_conditions": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "scope": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "read_only": {
            "type": "boolean"
          },
          "owned_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "validation_scope": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "overlap_rules": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "retirement_conditions": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          }
        }
      }
    }
  }
}
