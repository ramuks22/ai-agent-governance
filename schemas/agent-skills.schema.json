{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Skill Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registryVersion",
    "skills"
  ],
  "properties": {
    "registryVersion": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose",
          "trigger_conditions",
          "required_inputs",
          "procedure",
          "outputs",
          "validation",
          "revision_policy"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "\\S"
          },
          "purpose": {
            "type": "string",
            "pattern": "\\S"
          },
          "trigger_conditions": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "required_inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "procedure": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "validation": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "\\S"
            }
          },
          "revision_policy": {
            "type": "string",
            "pattern": "\\S"
          }
        }
      }
    }
  }
}
